{
  "clients": [
    {
      "url": "http://apollo:3100/loki/api/v1/push"
    }
  ],
  "positions": {
    "filename": "/var/cache/promtail/positions.yaml"
  },
  "scrape_configs": [
    {
      "job_name": "system",
      "journal": {
        "labels": {
          "job": "systemd-journal"
        },
        "max_age": "12h",
        "path": "/var/log/journal"
      },
      "relabel_configs": [
        {
          "source_labels": [
            "__journal__systemd_unit"
          ],
          "target_label": "unit"
        }
      ]
    }
  ],
  "server": {
    "grpc_listen_port": 0,
    "http_listen_port": 3800
  }
}
